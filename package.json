{
  "name": "haige-finance",
  "version": "0.1.0",
  "private": true,
  "description": "Small company local accounting desktop app",
  "main": "dist/main/main.js",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm prepare:preload && pnpm rebuild:electron && concurrently -k \"pnpm dev:renderer\" \"pnpm dev:main\" \"pnpm dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on http://127.0.0.1:5173 dist/main/main.js dist/preload/index.cjs && electron .",
    "build": "pnpm build:renderer && pnpm build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json && pnpm prepare:preload",
    "prepare:preload": "node scripts/copy-preload.cjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "verify": "pnpm typecheck && pnpm build && pnpm db:init-test && pnpm crud:smoke-test && pnpm transaction:smoke-test && pnpm project-stats:smoke-test && pnpm report:smoke-test && pnpm backup:smoke-test && pnpm export:smoke-test",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "db:init-test": "pnpm build:main && ELECTRON_RUN_AS_NODE=1 electron scripts/db-init-test.mjs",
    "crud:smoke-test": "pnpm build:main && ELECTRON_RUN_AS_NODE=1 electron scripts/crud-smoke-test.mjs",
    "transaction:smoke-test": "pnpm build:main && ELECTRON_RUN_AS_NODE=1 electron scripts/transaction-smoke-test.mjs",
    "project-stats:smoke-test": "pnpm build:main && ELECTRON_RUN_AS_NODE=1 electron scripts/project-stats-smoke-test.mjs",
    "report:smoke-test": "pnpm build:main && ELECTRON_RUN_AS_NODE=1 electron scripts/report-smoke-test.mjs",
    "backup:smoke-test": "pnpm build:main && ELECTRON_RUN_AS_NODE=1 electron scripts/backup-smoke-test.mjs",
    "export:smoke-test": "pnpm build:main && ELECTRON_RUN_AS_NODE=1 electron scripts/export-smoke-test.mjs",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.2",
    "antd": "^5.22.3",
    "better-sqlite3": "^11.7.0",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.38.3",
    "exceljs": "^4.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.1",
    "electron": "^33.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
